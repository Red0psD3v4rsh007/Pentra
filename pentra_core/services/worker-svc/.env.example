WORKER_FAMILY=recon
WORKER_EXECUTION_MODE=hybrid
WORKER_LIVE_TOOLS=httpx_probe,ffuf,nuclei,sqlmap,sqlmap_verify,custom_poc
WORKER_LIVE_TARGET_POLICY=local_only
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
ARTIFACT_STORE_PATH=/tmp/pentra/artifacts
WORKER_WORK_DIR=/tmp/pentra/jobs
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_CPU_LIMIT=2.0
CONTAINER_NETWORK_MODE=bridge
