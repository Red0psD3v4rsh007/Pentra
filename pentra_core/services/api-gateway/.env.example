APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3006","http://127.0.0.1:3006"]
DATABASE_URL=postgresql+asyncpg://pentra:pentra@localhost:5433/pentra_dev
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_PER_MINUTE=60
REQUEST_ID_HEADER=X-Request-ID
DEV_AUTH_BYPASS_ENABLED=true
DEV_AUTH_USER_ID=11111111-1111-1111-1111-111111111111
DEV_AUTH_TENANT_ID=00000000-0000-0000-0000-000000000001
DEV_AUTH_EMAIL=dev@pentra.local
DEV_AUTH_ROLES=owner,admin,member
DEV_AUTH_TIER=enterprise
ALLOW_LOCAL_DEV_RATE_LIMIT_BYPASS=true
MAX_SCAN_DEPTH=3
MAX_SCAN_ENDPOINTS=100
MAX_SCAN_SUBDOMAINS=50
MAX_SCOPE_HOSTS=10
MAX_SCOPE_CIDRS=4
MAX_HTTP_REQUESTS_PER_MINUTE=180
MAX_FFUF_REQUESTS_PER_MINUTE=90
MAX_NUCLEI_REQUESTS_PER_MINUTE=60
MAX_SQLMAP_THREADS=2
MAX_ZAP_MINUTES=5
MAX_DYNAMIC_NODES_PER_SCAN=6
MAX_VERIFICATIONS_PER_TYPE=2
MAX_STATEFUL_PAGES=60
MAX_STATEFUL_REPLAYS=20
ARTIFACT_RETENTION_DAYS=30
SCAN_IDEMPOTENCY_WINDOW_HOURS=24
AI_REASONING_ENABLED=true
AI_REASONING_TIMEOUT_SECONDS=20
AI_REASONING_MAX_RETRIES=2
AI_REASONING_MAX_TOKENS=1400
AI_REASONING_TEMPERATURE=0.2
AI_REASONING_PRIMARY_PROVIDER=anthropic
AI_REASONING_FALLBACK_PROVIDER=openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_DEEP_MODEL=claude-opus-4-1-20250805
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENAI_DEEP_MODEL=gpt-5.4
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_STANDARD_REASONING_EFFORT=low
OPENAI_DEEP_REASONING_EFFORT=high
LOG_LEVEL=INFO
